{
  "nmem": {
    "command": "nmem",
    "args": ["lsp"],
    "extensionToLanguage": {
      ".rs": "rust",
      ".py": "python",
      ".ts": "typescript",
      ".tsx": "typescriptreact",
      ".js": "javascript",
      ".jsx": "javascriptreact",
      ".go": "go",
      ".md": "markdown",
      ".toml": "toml",
      ".yaml": "yaml",
      ".yml": "yaml",
      ".json": "json"
    }
  }
}
